<Window x:Class="LunchWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LunchWPFApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Center" Margin="0,21,0,0" TextWrapping="Wrap" Text="What would you like to eat for lunch?" VerticalAlignment="Top"/>
        <RadioButton x:Name="wrapRadioButton" Content="Wrap" HorizontalAlignment="Left" Margin="240,82,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="paniniRadioButton" Content="Panini" HorizontalAlignment="Left" Margin="436,82,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="burritoRadioButton" Content="Burrito" HorizontalAlignment="Left" Margin="307,82,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="tacoRadioButton" Content="Taco" HorizontalAlignment="Center" Margin="0,82,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="burgerRadioButton" Content="Burger" HorizontalAlignment="Left" Margin="500,82,0,0" VerticalAlignment="Top"/>
        <GroupBox Header="GroupBox" Margin="215,63,215,318"/>

    </Grid>
</Window>
